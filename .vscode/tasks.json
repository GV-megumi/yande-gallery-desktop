{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "group": "build",
      "label": "npm: build",
      "detail": "Build the project"
    },
    {
      "type": "npm",
      "script": "dev",
      "group": "build",
      "label": "npm: dev",
      "detail": "Start all development watchers"
    },
    {
      "type": "npm",
      "script": "build:main",
      "group": "build",
      "label": "npm: build:main",
      "detail": "Build the Electron main process"
    },
    {
      "type": "npm",
      "script": "build:preload",
      "group": "build",
      "label": "npm: build:preload",
      "detail": "Build preload scripts"
    },
    {
      "label": "dev: build main and preload",
      "dependsOn": [
        "npm: build:main",
        "npm: build:preload"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "dev: start vite",
      "command": "npm run dev:renderer -- --host localhost --port 5173 --strictPort",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Local.*5173.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "dev: prepare electron",
      "dependsOn": [
        "dev: build main and preload",
        "dev: start vite"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
