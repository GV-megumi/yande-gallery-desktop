{
  // Copy this file to launch.json for local debugging if launch.json is missing.
  // launch.json is intentionally ignored by git.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: Dev",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/electron/dist/electron.exe"
      },
      "program": "${workspaceFolder}/build/main/index.js",
      "env": {
        "NODE_ENV": "development",
        "ELECTRON_ENABLE_LOGGING": "1"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "autoAttachChildProcesses": false,
      "preLaunchTask": "dev: prepare electron",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/build/main/**/*.js"],
      "presentation": {
        "hidden": false,
        "group": "dev",
        "order": 1
      }
    },
    {
      "name": "Electron: Production Build",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/electron/dist/electron.exe"
      },
      "program": "${workspaceFolder}/build/main/index.js",
      "env": {
        "NODE_ENV": "production",
        "ELECTRON_ENABLE_LOGGING": "1"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "autoAttachChildProcesses": false,
      "preLaunchTask": "npm: build",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/build/main/**/*.js"],
      "presentation": {
        "hidden": false,
        "group": "dev",
        "order": 2
      }
    },
    {
      "name": "Vite: Renderer",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:renderer", "--", "--host", "localhost", "--port", "5173", "--strictPort"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "presentation": {
        "hidden": false,
        "group": "dev",
        "order": 3
      }
    }
  ]
}
