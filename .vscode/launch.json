{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "1. 启动 Vite 服务器",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:renderer"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "presentation": {
        "hidden": false,
        "group": "dev",
        "order": 1
      }
    },
    {
      "name": "2. 启动 Electron (无代理)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "program": "${workspaceFolder}/build/main/index.js",
      "args": [],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "📦 仅编译（主进程 + Preload）",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/build/main/**/*.js"],
      "presentation": {
        "hidden": false,
        "group": "dev",
        "order": 2
      }
    },
    {
      "name": "2.1 启动 Electron (带代理)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "program": "${workspaceFolder}/build/main/index.js",
      "args": [
        "--proxy-server=http://127.0.0.1:7897"
      ],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "📦 仅编译（主进程 + Preload）",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/build/main/**/*.js"],
      "presentation": {
        "hidden": false,
        "group": "dev",
        "order": 2
      }
    },
    {
      "name": "3. 仅编译代码",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build:main"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "presentation": {
        "hidden": false,
        "group": "dev",
        "order": 3
      }
    }
  ]
}
