{
  "name": "yande-gallery-desktop",
  "version": "0.1.0",
  "description": "Personal Yande.re Gallery Manager",
  "main": "build/main/index.js",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "node scripts/build-preload.mjs --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "node scripts/build-preload.mjs",
    "build:renderer": "vite build",
    "rebuild": "electron-rebuild -f",
    "rebuild:sharp": "cd node_modules/sharp && npx node-gyp rebuild --target=39.2.1 --arch=x64 --dist-url=https://electronjs.org/headers",
    "postinstall": "echo Skipping postinstall rebuild",
    "pack": "electron-builder",
    "dist": "npm run build && electron-builder --publish=never",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/http-cache-semantics": "^4.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/ms": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^39.2.1",
    "electron-builder": "^24.6.4",
    "electron-devtools-installer": "^4.0.0",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^29.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "antd": "^5.11.0",
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "electron-store": "^8.1.0",
    "js-yaml": "^4.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.32.6",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.yourname.yande-gallery",
    "productName": "Yande Gallery",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": "dmg",
      "icon": "assets/icon.icns",
      "artifactName": "yande_gallery_mac_${arch}_v${version}_setup.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "yande_gallery_win_${arch}_v${version}_setup.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "artifactName": "yande_gallery_linux_${arch}_v${version}_setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
