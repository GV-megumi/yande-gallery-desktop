# Yande Gallery Desktop 环境配置
# 复制此文件为 .env 并修改

# 配置目录（存放 config.yaml 和数据库）
# 默认值：用户目录下的 .yandegallery
# Windows 示例: C:\Users\<用户名>\.yandegallery
# macOS/Linux 示例: ~/.yandegallery
#
# 目录结构：
#   CONFIG_DIR/
#     config.yaml          # 应用配置
#     gallery.db           # 数据库
#     data/                # 运行数据（由 config.yaml 的 dataPath 控制）
#       thumbnails/        # 缩略图缓存
#       cache/             # Booru 图片缓存
#       downloads/         # 默认下载目录
#       app.log            # 应用日志
#
# CONFIG_DIR=
